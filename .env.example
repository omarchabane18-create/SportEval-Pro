# Environment Configuration
# Copy this file to .env and fill in your values

# Database
DATABASE_URL=sqlite:///./data/database.db
# DATABASE_URL=postgresql://user:password@localhost/sporteval_pro  # For production

# Application
APP_NAME=SportEval Pro
APP_DEBUG=True
APP_VERSION=1.0.0

# Server
SERVER_HOST=127.0.0.1
SERVER_PORT=8000

# Security
SECRET_KEY=your-secret-key-here-change-this
JWT_SECRET=your-jwt-secret-here-change-this

# Cloud Services (Optional)
GOOGLE_DRIVE_CREDENTIALS=credentials.json
ONEDRIVE_API_KEY=your-onedrive-api-key

# AI Services (Optional)
OPENAI_API_KEY=your-openai-api-key
HUGGINGFACE_API_KEY=your-huggingface-api-key

# Email (Optional)
SMTP_SERVER=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-app-password

# Logging
LOG_LEVEL=INFO
LOG_FILE=logs/app.log

# Features
ENABLE_AI=False
ENABLE_CLOUD_SYNC=False
ENABLE_MOBILE_API=False
